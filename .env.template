# Server
PORT=8080

# MySQL REST Service (MRS)
MRS_URL=https://localhost:33060/myService
MRS_SCHEMA=sakila
MRS_OBJECT=actor
MRS_AUTH_APP=MySQL
MRS_USERNAME=
MRS_PASSWORD=
MRS_SESSION_TYPE=bearer
MRS_INSECURE_TLS=true

# Optional OCI GenAI (not wired by default)
OCI_REGION=us-ashburn-1
OCI_COMPARTMENT_ID=
OCI_MODEL_NAME=meta.llama-3.3-70b-instruct
# Optional: override API version if your tenancy uses a different date
# e.g., 2023-11-30 or 20231130
# OCI_GENAI_API_VERSION=2024-10-30
# Optional: If using actions/chat (On Demand serving), set modelId
# OCI_MODEL_ID=ocid1.generativeaimodel.oc1..exampleuniqueid
# Optional: Use OCI SDK instead of raw REST (requires ~/.oci/config)
# OCI_USE_SDK=1
# OCI_SDK_CONFIG_LOCATION=/Users/you/.oci/config
# OCI_SDK_CONFIG_PROFILE=DEFAULT
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_FINGERPRINT=
# Choose one of the following for your API key:
# 1) Inline private key PEM (escape newlines as \n)
# OCI_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# 2) Or path to the private key file
# OCI_PRIVATE_KEY_PATH=/absolute/path/to/oci_api_key.pem
